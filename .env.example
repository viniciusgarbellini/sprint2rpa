# Banco (mesma instância da Sprint 1) ---------------------------------------
POSTGRES_DB=rpa_assets
POSTGRES_USER=rpa
POSTGRES_PASSWORD=rpa_secret_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Aplicação -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agendamento das RPAs (cron: m h dom mon dow) ------------------------------
SCHEDULE_NAMEPLATE_BOT=*/2 * * * *
SCHEDULE_ASSOCIATION_BOT=*/3 * * * *

# Autenticação --------------------------------------------------------------
# Vazio = usa os usuários demo embutidos (operador/operador123, admin/admin123).
# Para produção, gere hashes com sprint2.app.auth.hash_password e defina:
# AUTH_USERS=operador:operador:<sha256hex>,admin:admin:<sha256hex>
AUTH_USERS=
